{
  "name": "life-mirror-2050",
  "version": "1.0.0",
  "description": "LifeMirror 2050: Mirror Your Life, Predict Your Health",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable",
    "build-installer": "electron-builder --win nsis"
  },
  "author": "Brainiacs",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.lifemirror2050",
    "productName": "LifeMirror 2050",
    "directories": {
      "output": "dist"
    },
    "files": [
      "index.html",
      "style.css",
      "app.js",
      "main.js"
    ],
    "win": {
      "target": "portable",
      "icon": "icon.ico"
    },
    "portable": {
      "artifactName": "LifeMirror_2050.exe"
    }
  }
}